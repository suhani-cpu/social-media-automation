<tr><td>Language</td><td>TypeScript</td><td>5.3</td></tr>
<tr><td>Styling</td><td>TailwindCSS</td><td>3.4</td></tr>
<tr><td>UI Components</td><td>shadcn/ui</td><td>-</td></tr>
