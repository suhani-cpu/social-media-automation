# Production Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=social_media

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your-redis-password-here

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Frontend URL
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_MAX_UPLOAD_SIZE=524288000

# ============================================
# AWS S3 Configuration
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Optional: S3 bucket for database backups
AWS_S3_BACKUP_BUCKET=your-backup-bucket-name

# ============================================
# Instagram Configuration
# ============================================
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# ============================================
# YouTube OAuth Configuration
# ============================================
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=https://yourdomain.com/api/oauth/youtube/callback

# ============================================
# Facebook OAuth Configuration
# ============================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/oauth/facebook/callback

# ============================================
# Monitoring (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# New Relic License Key
NEW_RELIC_LICENSE_KEY=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# SSL/TLS Configuration
# ============================================
# Path to SSL certificate files (inside nginx container)
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem
