# Test Environment Configuration
# Copy this file to .env.test and fill in your values

# Environment
TEST_ENV=local
NODE_ENV=test

# Application URLs
BASE_URL=http://localhost:3001
API_URL=http://localhost:3000/api

# Database (Test Database - DO NOT use production!)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_automation_test

# Redis
REDIS_URL=redis://localhost:6379

# Test User Credentials
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=AdminPassword123!

# OAuth Test Credentials (use test/sandbox accounts)
# Instagram
TEST_INSTAGRAM_USERNAME=
TEST_INSTAGRAM_PASSWORD=

# YouTube
TEST_YOUTUBE_EMAIL=
TEST_YOUTUBE_PASSWORD=

# Facebook
TEST_FACEBOOK_EMAIL=
TEST_FACEBOOK_PASSWORD=

# AWS S3 Test Bucket (use separate test bucket)
AWS_S3_BUCKET=social-media-automation-test
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Feature Flags (if applicable)
FEATURE_FLAG_NEW_UI=true
FEATURE_FLAG_AUTO_PUBLISH=false

# Test Video Files
TEST_VIDEO_PATH=./tests/support/fixtures/test-video.mp4
TEST_LARGE_VIDEO_PATH=./tests/support/fixtures/large-video.mp4

# API Rate Limiting (disable for tests)
DISABLE_RATE_LIMIT=true

# Logging
LOG_LEVEL=error

# Timeouts (in milliseconds)
API_TIMEOUT=30000
UPLOAD_TIMEOUT=120000
PROCESSING_TIMEOUT=300000
