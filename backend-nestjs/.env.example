# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_automation

# ============================================
# REDIS (for Bull queues + publish progress)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-secret-here
JWT_EXPIRY=7d

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:3001

# ============================================
# CORS (for CMS embedding)
# ============================================
# Set ALLOW_ALL_ORIGINS=true to allow embedding from any domain
ALLOW_ALL_ORIGINS=false
# Comma-separated list of allowed origins (used when ALLOW_ALL_ORIGINS=false)
ALLOWED_ORIGINS=http://localhost:3001

# ============================================
# AWS S3 (Optional - falls back to local /tmp/storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================
# INSTAGRAM (Facebook Developers)
# ============================================
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback

# ============================================
# YOUTUBE (Google Cloud Console)
# ============================================
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

# ============================================
# FACEBOOK
# ============================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/oauth/facebook/callback

# ============================================
# GOOGLE DRIVE (video import)
# ============================================
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ============================================
# STAGE OTT API (Optional)
# ============================================
STAGE_OTT_API_URL=
STAGE_OTT_API_KEY=
STAGE_OTT_SECRET_KEY=

# ============================================
# AI CAPTION GENERATION
# ============================================
ANTHROPIC_API_KEY=
