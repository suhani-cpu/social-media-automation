{
  "version": 2,
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "npm run build",
  "functions": {
    "dist/main.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-scheduled",
      "schedule": "*/5 * * * *"
    }
  ]
}
