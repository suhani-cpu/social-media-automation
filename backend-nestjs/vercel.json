{
  "version": 2,
  "installCommand": "npm install && npx prisma generate",
  "functions": {
    "dist/main.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/videos/upload",
      "dest": "dist/main.js",
      "headers": {
        "x-vercel-proxy-body-size": "100mb"
      }
    },
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-scheduled",
      "schedule": "*/5 * * * *"
    }
  ]
}
